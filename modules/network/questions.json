{
  "version": "v1.0",
  "product": "smb-network-baseline-assessment",
  "principles": {
    "not_sure_treated_as_fail": true,
    "no_identity_required_for_assessment": true,
    "email_optional_after_report": true,
    "scope_upper_device_limit": 1000
  },
  "sections": [
    {
      "id": "A_SCOPE",
      "title": "Scope & Reality",
      "scored": false,
      "questions": [
        {
          "id": "A1_DEVICE_COUNT",
          "type": "single_choice",
          "prompt": "Approximately how many total devices are on your network? (Include laptops, desktops, phones, printers, cameras, IoT, etc.)",
          "scored": false,
          "options": [
            {
              "key": "U_1_25",
              "label": "1–25"
            },
            {
              "key": "U_26_100",
              "label": "26–100"
            },
            {
              "key": "U_101_300",
              "label": "101–300"
            },
            {
              "key": "U_301_1000",
              "label": "301–1000"
            },
            {
              "key": "U_1000_PLUS",
              "label": "1000+"
            }
          ]
        },
        {
          "id": "A2_VENDOR_PROFILE",
          "type": "single_choice",
          "prompt": "Is your network built using a single vendor or mixed vendors?",
          "scored": false,
          "options": [
            {
              "key": "SINGLE",
              "label": "Single vendor"
            },
            {
              "key": "MIXED",
              "label": "Mixed vendors"
            },
            {
              "key": "NOT_SURE",
              "label": "Not sure"
            }
          ]
        },
        {
          "id": "A3_SITE_COUNT",
          "type": "single_choice",
          "prompt": "How many physical locations are connected to this network?",
          "scored": false,
          "options": [
            {
              "key": "SINGLE_SITE",
              "label": "Single site"
            },
            {
              "key": "MULTI_SITE",
              "label": "Multiple sites (site-to-site)"
            }
          ]
        }
      ]
    },
    {
      "id": "B_INTENT",
      "title": "Business Intent",
      "scored": false,
      "questions": [
        {
          "id": "B1_USER_GROUPS",
          "type": "single_choice",
          "prompt": "Who needs network access?",
          "scored": false,
          "options": [
            {
              "key": "STAFF_ONLY",
              "label": "Staff only"
            },
            {
              "key": "STAFF_GUESTS",
              "label": "Staff + Guests"
            },
            {
              "key": "STAFF_GUESTS_IOT",
              "label": "Staff + Guests + IoT (CCTV, printers, TVs, access systems)"
            }
          ]
        },
        {
          "id": "B2_LOCAL_RESOURCES",
          "type": "single_choice",
          "prompt": "Do internal devices need to communicate locally (e.g., file servers, NAS, printers, internal apps)?",
          "scored": false,
          "options": [
            {
              "key": "CLOUD_ONLY",
              "label": "No (cloud/SaaS only)"
            },
            {
              "key": "LOCAL_REQUIRED",
              "label": "Yes (local resources exist)"
            }
          ]
        },
        {
          "id": "B3_BYOD_WIFI",
          "type": "single_choice",
          "prompt": "Do employees connect personal devices (phones, personal laptops, tablets, smart watches) to office Wi-Fi?",
          "scored": false,
          "score_category": "segmentation",
          "options": [
            {
              "key": "YES_SEPARATE",
              "label": "Yes (separate SSID/network)"
            },
            {
              "key": "YES_SAME",
              "label": "Yes (same network as work devices)"
            },
            {
              "key": "NO",
              "label": "No"
            }
          ]
        }
      ]
    },
    {
      "id": "C_PERIMETER",
      "title": "Perimeter & Remote Access",
      "scored": true,
      "gates": [
        "G1"
      ],
      "questions": [
        {
          "id": "C1_WAN_ADMIN_EXPOSURE",
          "type": "single_choice",
          "prompt": "Is the login interface of any network device accessible from the public internet? (Firewall, router, switch, Wi-Fi controller)",
          "scored": true,
          "score_category": "perimeter",
          "gate": "G1",
          "options": [
            {
              "key": "NO",
              "label": "No"
            },
            {
              "key": "YES",
              "label": "Yes"
            },
            {
              "key": "NOT_SURE",
              "label": "Not sure"
            }
          ]
        },
        {
          "id": "C2_REMOTE_ACCESS_METHOD",
          "type": "single_choice",
          "prompt": "How do employees access internal systems from outside the office?",
          "scored": true,
          "score_category": "perimeter",
          "gate": "G1",
          "options": [
            {
              "key": "VPN",
              "label": "Secure VPN"
            },
            {
              "key": "CLOUD_ONLY",
              "label": "Cloud apps only (no internal network access)"
            },
            {
              "key": "PORT_FORWARDING",
              "label": "Port forwarding / exposed RDP, SSH, or web admin"
