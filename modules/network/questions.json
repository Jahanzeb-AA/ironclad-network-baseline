            {
              "key": "NO_REMOTE",
              "label": "No remote access"
            },
            {
              "key": "NOT_SURE",
              "label": "Not sure"
            }
          ]
        },
        {
          "id": "C3_ADMIN_MFA",
          "type": "single_choice",
          "prompt": "Is multi-factor authentication (MFA) enforced for network admin access?",
          "scored": true,
          "score_category": "identity",
          "gate": "G1",
          "options": [
            {
              "key": "YES",
              "label": "Yes"
            },
            {
              "key": "NO",
              "label": "No"
            },
            {
              "key": "NOT_SURE",
              "label": "Not sure"
            }
          ]
        }
      ]
    },
