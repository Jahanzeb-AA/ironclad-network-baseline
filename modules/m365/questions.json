{
  "version": "v1.3",
  "product": "m365-baseline-assessment",
  "principles": {
    "not_sure_treated_as_fail": true,
    "no_identity_required_for_assessment": true,
    "email_optional_after_report": true
  },
  "sections": [
    {
      "id": "A_SCOPE",
      "title": "Scope & Licensing",
      "scored": false,
      "questions": [
        {
          "id": "A1_USER_COUNT",
          "type": "single_choice",
          "prompt": "How many licensed Microsoft 365 users do you have?",
          "scored": false,
          "options": [
            { "key": "U_1_25", "label": "1–25" },
            { "key": "U_26_100", "label": "26–100" },
            { "key": "U_101_300", "label": "101–300" },
            { "key": "U_301_1000", "label": "301–1000" },
            { "key": "U_1000_PLUS", "label": "1000+" }
          ]
        },
        {
          "id": "A2_LICENSE_TYPE",
          "type": "single_choice",
          "prompt": "What is your primary Microsoft 365 license level?",
          "scored": false,
          "options": [
            { "key": "BASIC_STANDARD", "label": "Business Basic / Standard" },
            { "key": "PREMIUM", "label": "Business Premium" },
            { "key": "ENTERPRISE", "label": "Enterprise (E3 / E5)" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        }
      ]
    },

    {
      "id": "B_IDENTITY",
      "title": "Identity & Access",
      "scored": true,
      "questions": [
        {
          "id": "B1_MFA_ENFORCEMENT",
          "type": "single_choice",
          "prompt": "Is Multi-Factor Authentication (MFA) strictly required for EVERY user to log in?",
          "scored": true,
          "score_category": "identity",
          "gate": "G1",
          "options": [
            { "key": "YES", "label": "Yes (All users)" },
            { "key": "ADMIN_ONLY", "label": "Only IT admins" },
            { "key": "NO", "label": "No" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        },
        {
          "id": "B2_LEGACY_AUTH",
          "type": "single_choice",
          "prompt": "Are legacy authentication protocols (SMTP, IMAP, POP3) completely blocked?",
          "scored": true,
          "score_category": "identity",
          "gate": "G2",
          "options": [
            { "key": "YES", "label": "Yes, blocked" },
            { "key": "NO", "label": "No, allowed" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        },
        {
          "id": "B3_ADMIN_ACCOUNTS",
          "type": "single_choice",
          "prompt": "Do administrators use separate, dedicated admin accounts?",
          "scored": true,
          "score_category": "identity",
          "options": [
            { "key": "SEPARATE", "label": "Yes, separate accounts" },
            { "key": "DAILY_EMAIL", "label": "No, daily email accounts" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        },
        {
          "id": "B4_CONDITIONAL_ACCESS",
          "type": "single_choice",
          "prompt": "Are Conditional Access policies used to enforce login restrictions (device, location, risk)?",
          "scored": true,
          "score_category": "identity",
          "options": [
            { "key": "YES", "label": "Yes" },
            { "key": "NO", "label": "No" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        },
        {
          "id": "B5_GLOBAL_ADMINS",
          "type": "single_choice",
          "prompt": "How many Global Administrator accounts exist?",
          "scored": true,
          "score_category": "identity",
          "options": [
            { "key": "LT_3", "label": "1–3 (Recommended)" },
            { "key": "R_4_8", "label": "4–8" },
            { "key": "GT_8", "label": "More than 8" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        }
      ]
    },

    {
      "id": "C_EMAIL",
      "title": "Email Security",
      "scored": true,
      "questions": [
        {
          "id": "C1_AUTO_FORWARDING",
          "type": "single_choice",
          "prompt": "Are users prevented from forwarding company emails to external personal accounts?",
          "scored": true,
          "score_category": "email",
          "gate": "G3",
          "options": [
            { "key": "YES_BLOCKED", "label": "Yes, blocked" },
            { "key": "NO_ALLOWED", "label": "No, allowed" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        },
        {
          "id": "C2_EXTERNAL_BANNER",
          "type": "single_choice",
          "prompt": "Do external emails display a warning banner?",
          "scored": true,
          "score_category": "email",
          "options": [
            { "key": "YES", "label": "Yes" },
            { "key": "NO", "label": "No" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        },
        {
          "id": "C3_SPAM_PHISHING",
          "type": "single_choice",
          "prompt": "Is advanced phishing protection enabled (Defender or similar)?",
          "scored": true,
          "score_category": "email",
          "options": [
            { "key": "YES", "label": "Yes" },
            { "key": "NO", "label": "No" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        },
        {
          "id": "C4_EMAIL_AUTH",
          "type": "single_choice",
          "prompt": "Are SPF, DKIM, and DMARC configured for your domain?",
          "scored": true,
          "score_category": "email",
          "options": [
            { "key": "YES", "label": "Fully configured" },
            { "key": "PARTIAL", "label": "Partially configured" },
            { "key": "NO", "label": "Not configured" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        }
      ]
    },

    {
      "id": "D_DATA",
      "title": "Data Protection",
      "scored": true,
      "questions": [
        {
          "id": "D1_SHAREPOINT_SHARING",
          "type": "single_choice",
          "prompt": "Can files be shared using 'Anyone with the link' (anonymous access)?",
          "scored": true,
          "score_category": "data",
          "options": [
            { "key": "YES", "label": "Yes, no expiry" },
            { "key": "YES_WITH_EXPIRATION", "label": "Yes, with expiry" },
            { "key": "NO_RESTRICTED", "label": "No" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        },
        {
          "id": "D2_M365_BACKUPS",
          "type": "single_choice",
          "prompt": "Do you use an independent backup solution for M365 data?",
          "scored": true,
          "score_category": "data",
          "gate": "G5",
          "options": [
            { "key": "YES", "label": "Yes" },
            { "key": "NO_RELY_ON_MICROSOFT", "label": "No, relying on Microsoft only" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        }
      ]
    },

    {
      "id": "E_OPERATIONS",
      "title": "Operations & Devices",
      "scored": true,
      "questions": [
        {
          "id": "E1_AUDIT_LOGGING",
          "type": "single_choice",
          "prompt": "Is audit logging enabled to track user and admin activity?",
          "scored": true,
          "score_category": "operations",
          "gate": "G4",
          "options": [
            { "key": "YES", "label": "Yes" },
            { "key": "NO", "label": "No" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        },
        {
          "id": "E2_DEVICE_COMPLIANCE",
          "type": "single_choice",
          "prompt": "Are devices required to meet security standards before accessing M365?",
          "scored": true,
          "score_category": "devices",
          "options": [
            { "key": "YES", "label": "Yes" },
            { "key": "PARTIAL", "label": "Partially enforced" },
            { "key": "NO", "label": "No" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        }
      ]
    },

    {
      "id": "F_CONTEXT",
      "title": "Business Context",
      "scored": false,
      "questions": [
        {
          "id": "F1_SENSITIVE_DATA",
          "type": "single_choice",
          "prompt": "Does your organization handle sensitive data (financial, HR, client data)?",
          "scored": false,
          "options": [
            { "key": "YES", "label": "Yes" },
            { "key": "NO", "label": "No" },
            { "key": "NOT_SURE", "label": "Not sure" }
          ]
        }
      ]
    }
  ],

  "gates": [
    { "id": "G1", "name": "MFA Not Enforced", "cap": 40 },
    { "id": "G2", "name": "Legacy Auth Not Blocked", "cap": 45 },
    { "id": "G3", "name": "External Forwarding Allowed", "cap": 55 },
    { "id": "G4", "name": "No Audit Logging", "cap": 65 },
    { "id": "G5", "name": "No Independent Backups", "cap": 70 }
  ]
}