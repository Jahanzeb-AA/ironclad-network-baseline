          "options": [
            { "key": "U_1_25", "label": "1-25" },
            { "key": "U_26_100", "label": "26-100" },
            { "key": "U_101_300", "label": "101-300" },
            { "key": "U_301_1000", "label": "301-1000" },
            { "key": "U_1000_PLUS", "label": "1000+" }
